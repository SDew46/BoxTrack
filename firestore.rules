rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isCoach() {
      return isAuthenticated() && isVerified() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data)
          .data.role == 'coach';
    }

    function isVerified() {
      return request.auth.token.email_verified == true ||
        request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // User profile — field-level protection
    match /users/{userId}/profile/data {
      // Unverified users can read their own profile —
      // required for the auth flow to determine which
      // screen to show post-registration. Write operations
      // correctly require verification.
      allow read: if isAuthenticated() && isOwner(userId);

      // On creation: role must be member, sgpt must be false, gym must be 8RB
      allow create: if isAuthenticated()
        && isOwner(userId)
        && isVerified()
        && request.resource.data.role == 'member'
        && request.resource.data.sgpt == false
        && request.resource.data.gym == '8RB';

      // On self-update: role, gym, joinDate are immutable.
      // sgpt can only be set to false (migration / no self-elevation).
      allow update: if isAuthenticated()
        && isOwner(userId)
        && isVerified()
        && !request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasAny(['role', 'gym', 'joinDate'])
        && (!request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['sgpt'])
            || request.resource.data.sgpt == false);

      // Coach can update role and/or sgpt fields on other users' profiles
      allow update: if isCoach() && isVerified()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'sgpt']);
    }

    // User subcollections — owner only, verified only
    match /users/{userId}/sessions/{sessionId} {
      allow read, write: if isAuthenticated()
        && isOwner(userId)
        && isVerified();
    }

    match /users/{userId}/boxingSessions/{sessionId} {
      allow read, write: if isAuthenticated()
        && isOwner(userId)
        && isVerified();
    }

    match /users/{userId}/customCombos/{comboId} {
      allow read, write: if isAuthenticated()
        && isOwner(userId)
        && isVerified();
    }

    match /users/{userId}/customSessions/{sessionId} {
      allow read, write: if isAuthenticated()
        && isOwner(userId)
        && isVerified();
    }

    // Assigned sessions — member reads/updates own (status+completedAt only), coach full access
    match /users/{userId}/assignedSessions/{sessionId} {
      allow read: if isAuthenticated() && isVerified() && isOwner(userId);
      allow create: if isCoach() && isVerified();
      allow update: if isAuthenticated() && isVerified() && isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'completedAt']);
      allow delete: if isCoach() && isVerified();
      // Coach can read and write all users' assigned sessions
      allow read, write: if isCoach() && isVerified();
    }

    // Gym config — all verified members read, coach only write (own gym)
    match /gym/{gymId}/config/{docId} {
      allow read: if isAuthenticated() && isVerified();
      // Coach can only write to their own gym's config —
      // scoped by the gym field on their profile document
      allow write: if isCoach() && isVerified()
        && gymId == get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data).data.gym;
    }

    // SGPT sessions — coach reads all; SGPT members read only active; coach writes own gym
    match /gym/{gymId}/sgptSessions/{sessionId} {
      allow read: if isCoach() && isVerified();
      allow read: if isAuthenticated() && isVerified()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data).data.sgpt == true
        && resource.data.active == true;
      allow write: if isCoach() && isVerified()
        && gymId == get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data).data.gym;
    }

    // Members registry — coach reads all, members write their own entry
    match /gym/{gymId}/members/{memberId} {
      allow read: if isCoach() && isVerified();
      allow create: if isAuthenticated() && isVerified() && memberId == request.auth.uid;
      allow update: if (isAuthenticated() && isVerified() && memberId == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'sgpt']))
                   || (isCoach() && isVerified()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'sgpt']));
    }

    // Announcements — all verified members read, coach only write
    match /gym/{gymId}/announcements/{announcementId} {
      allow read: if isAuthenticated() && isVerified();
      allow write: if isCoach() && isVerified();
    }

    // Deny everything else explicitly
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
